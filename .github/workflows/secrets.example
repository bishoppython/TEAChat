# ============================================================
# GitHub Actions Secrets - Exemplo de Configuração
# ============================================================
# Este arquivo lista todos os secrets necessários para o
# deploy automático na AWS.
#
# ⚠️ NUNCA commit este arquivo no repositório!
# Use apenas como referência para configurar no GitHub.
# ============================================================

# ------------------------------------------------------------
# 1. AWS Credentials (Obrigatórios)
# ------------------------------------------------------------
# Como obter:
#   1. Acesse AWS Console → IAM → Users
#   2. Create user (ex: symyah-deployer)
#   3. Attach policy: AdministratorAccess
#   4. Create access key
#   5. Copie as credenciais

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ------------------------------------------------------------
# 2. Database Configuration (Obrigatório)
# ------------------------------------------------------------
# Após executar aws-deploy/04-create-rds.sh e 05-enable-pgvector.sh,
# obtenha a connection string:

DATABASE_URL=postgresql://postgres:SENHA_DO_RDS@symyah-postgres.XXXXXXXX.rds.amazonaws.com:5432/symyah_db?sslmode=require

# Como obter:
#   1. Execute: bash aws-deploy/04-create-rds.sh
#   2. A senha está em aws-deploy/.env.aws (DB_PASSWORD)
#   3. O endpoint está em aws-deploy/.env.aws (DB_ENDPOINT)

# ------------------------------------------------------------
# 3. API Keys (Obrigatório pelo menos GOOGLE_API_KEY)
# ------------------------------------------------------------

# Google AI Studio (Gemini)
# Obter em: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyDXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenAI (Opcional, mas recomendado)
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ------------------------------------------------------------
# 4. Application Secrets (Obrigatório)
# ------------------------------------------------------------

# Chave secreta para JWT e sessões
# Gere uma nova: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# 5. Variáveis Opcionais
# ------------------------------------------------------------

# Ollama (se usar modelos locais)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_MODEL=llama3

# Configurações RAG
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.5
MAX_CONTEXT_TOKENS=2048

# Configurações de Servidor
HOST=0.0.0.0
PORT=8000

# ============================================================
# COMO CONFIGURAR NO GITHUB
# ============================================================
#
# 1. Acesse seu repositório no GitHub
# 2. Vá em Settings → Secrets and variables → Actions
# 3. Clique em "New repository secret"
# 4. Adicione cada secret individualmente
#
# Secrets obrigatórios para deploy:
#   - AWS_ACCESS_KEY_ID
#   - AWS_SECRET_ACCESS_KEY
#   - AWS_REGION
#   - DATABASE_URL
#   - GOOGLE_API_KEY
#   - SECRET_KEY
#
# Secrets opcionais:
#   - OPENAI_API_KEY
#
# ============================================================

# ============================================================
# TESTE DE CONEXÃO
# ============================================================
#
# Após configurar, teste no GitHub Actions:
#
# 1. Vá em Actions → Deploy para AWS App Runner
# 2. Clique em "Run workflow"
# 3. Selecione a branch main
# 4. Clique em "Run workflow"
# 5. Acompanhe o log
#
# ============================================================
