# Google API Key (obrigatória para embeddings)
GOOGLE_API_KEY=

# OpenAI API Key (opcional, mas recomendada)
OPENAI_API_KEY=

# Database Configuration (obrigatória)
DATABASE_URL=postgresql://neondb_owner:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/neondb?sslmode=require&channel_binding=require

# Ollama Configuration (opcional)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_MODEL=llama3
DEFAULT_MODEL=gpt-3.5-turbo

# RAG Configuration
MAX_CONTEXT_TOKENS=2048
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.5

# Training Configuration
TRAINING_BATCH_SIZE=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Server Configuration
HOST=0.0.0.0
PORT=8000
