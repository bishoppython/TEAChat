# =============================================================================
# CONFIGURAÇÃO DO SISTEMA DE IA PARA PSICOLOGIA CLÍNICA
# Fallback local está DESATIVADO - usando apenas OpenAI e Google Gemini
# =============================================================================

# -----------------------------------------------------------------------------
# API KEYS (Obrigatório: pelo menos uma deve ser configurada)
# -----------------------------------------------------------------------------

# OpenAI API Key (PROVEDOR PRIMÁRIO - recomendada)
OPENAI_API_KEY=

# Google Gemini API Key (PROVEDOR DE FALLBACK)
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (Obrigatória)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://neondb_owner:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/neondb?sslmode=require&channel_binding=require

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION (Obrigatória)
# -----------------------------------------------------------------------------
SECRET_KEY=sua_chave_secreta_aqui_mude_em_producao

# -----------------------------------------------------------------------------
# RAG CONFIGURATION
# -----------------------------------------------------------------------------
MAX_CONTEXT_TOKENS=2048
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.5

# -----------------------------------------------------------------------------
# TRAINING CONFIGURATION
# -----------------------------------------------------------------------------
TRAINING_BATCH_SIZE=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# MODELO PADRÃO
# -----------------------------------------------------------------------------
DEFAULT_MODEL=gpt-3.5-turbo

# =============================================================================
# NOTAS:
# - Fallback local está DESATIVADO
# - O sistema usará OpenAI como provedor primário e Google Gemini como fallback
# - Ambos provedores devem ter suas APIs configuradas acima
# =============================================================================
