# =============================================================================
# SYMYAH - Configuração de Ambiente para Produção EC2
# =============================================================================
# Use este arquivo como base para produção em EC2
# Copie para .env.production e ajuste os valores
# =============================================================================

# -----------------------------------------------------------------------------
# Configurações do Banco de Dados
# -----------------------------------------------------------------------------
POSTGRES_DB=symyah_db
POSTGRES_USER=symyah_user
POSTGRES_PASSWORD=USE_UMA_SENHA_FORTE_AQUI

# -----------------------------------------------------------------------------
# Chaves de API para IA
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=COLOQUE_SUA_GOOGLE_API_KEY_AQUI
OPENAI_API_KEY=COLOQUE_SUA_OPENAI_API_KEY_AQUI

# -----------------------------------------------------------------------------
# Segurança - GERE UMA NOVA CHAVE PARA PRODUÇÃO
# -----------------------------------------------------------------------------
SECRET_KEY=GERE_UMA_CHAVE_SECRETA_FORTE_AQUI

# -----------------------------------------------------------------------------
# Configurações RAG
# -----------------------------------------------------------------------------
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.5
DEFAULT_MODEL=gpt-3.5-turbo
