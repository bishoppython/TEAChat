# =============================================================================
# SYMYAH - Arquivo de Configuração de Ambiente (Exemplo)
# =============================================================================
# Copie este arquivo para .env e preencha com os valores apropriados
# Comando: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Configurações do Banco de Dados (Obrigatório)
# -----------------------------------------------------------------------------
POSTGRES_DB=symyah_db
POSTGRES_USER=symyah_user
POSTGRES_PASSWORD=mude_esta_senha_em_producao

# -----------------------------------------------------------------------------
# Chaves de API para IA (Obrigatório pelo menos GOOGLE_API_KEY)
# -----------------------------------------------------------------------------
# Google API Key para embeddings (obrigatória)
GOOGLE_API_KEY=sua_google_api_key_aqui

# OpenAI API Key para geração de respostas (opcional, mas recomendada)
OPENAI_API_KEY=sua_openai_api_key_aqui

# -----------------------------------------------------------------------------
# Segurança (Obrigatório em produção)
# -----------------------------------------------------------------------------
# Gere uma chave secreta forte para produção
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=mude_esta_chave_secreta_em_producao

# -----------------------------------------------------------------------------
# Configurações RAG (Opcional - valores padrão recomendados)
# -----------------------------------------------------------------------------
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.5

# -----------------------------------------------------------------------------
# Modelo Padrão (Opcional)
# -----------------------------------------------------------------------------
DEFAULT_MODEL=gpt-3.5-turbo

# -----------------------------------------------------------------------------
# Configurações Ollama (Opcional - para modelos locais)
# -----------------------------------------------------------------------------
# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# Configurações de Servidor (Opcional)
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Configurações de Treinamento (Opcional)
# -----------------------------------------------------------------------------
# TRAINING_BATCH_SIZE=4
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
