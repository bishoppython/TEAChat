# =============================================================================
# .gitignore para Deploy SYMYAH
# =============================================================================

# Arquivos de ambiente (NÃO commitar em produção!)
.env
.env.production
.env.local

# Logs
logs/
*.log
npm-debug.log*

# Backups
backups/
*.sql
*.sql.gz

# SSL/TLS
nginx/ssl/
*.pem
*.key
*.crt

# Dados do PostgreSQL
postgres_data/

# Nginx
nginx_logs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docker
.docker/

# Temporários
tmp/
temp/
*.tmp

# Testes
.pytest_cache/
.coverage
htmlcov/
.tox/

# NLTK data (grande, pode ser baixado)
nltk_data/
