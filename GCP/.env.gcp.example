# =============================================================================
# VARIÁVEIS DE AMBIENTE — Google Cloud Platform
# TEAChat / SYMYAH
#
# IMPORTANTE: Este arquivo é apenas um TEMPLATE para referência.
# NÃO preencha os valores aqui — use o Secret Manager do GCP!
#
# Instruções para criar os secrets:
#   gcloud secrets create NOME_DO_SECRET --data-file=-
#   echo -n "seu_valor" | gcloud secrets versions add NOME_DO_SECRET --data-file=-
# =============================================================================

# --- Secrets (armazenar no Secret Manager) ---
# Estes valores são injetados automaticamente no Cloud Run via --set-secrets

OPENAI_API_KEY=            # Secret Manager: OPENAI_API_KEY
GOOGLE_API_KEY=            # Secret Manager: GOOGLE_API_KEY
DATABASE_URL=              # Secret Manager: DATABASE_URL (Neon.tech PostgreSQL+pgvector)
SECRET_KEY=                # Secret Manager: SECRET_KEY (chave JWT)

# --- Variáveis de ambiente (não-sensíveis, passadas via --set-env-vars) ---
# Estas são passadas diretamente no deploy, não precisam do Secret Manager

HOST=0.0.0.0
PORT=8080                  # IMPORTANTE: Cloud Run usa 8080, não 8000!

# IA / RAG
MAX_CONTEXT_TOKENS=2048
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.5
DEFAULT_MODEL=gpt-3.5-turbo

# Treinamento
TRAINING_BATCH_SIZE=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# =============================================================================
# FORMATO DA DATABASE_URL (Neon.tech):
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require
#
# Exemplo:
#   postgresql://neondb_owner:abc123@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# =============================================================================
